CREATE TABLE Translation (
    id TEXT NOT NULL PRIMARY KEY,
    query TEXT NOT NULL,
    answer TEXT NOT NULL,
    created INTEGER NOT NULL
);

insertTranslation:
INSERT INTO Translation(id, query, answer, created)
VALUES(?, ?, ?, ?);

removeAllTranslations:
DELETE FROM Translation;

deleteTranslation:
DELETE FROM Translation WHERE id = ?;

selectAllTranslationsInfo:
SELECT Translation.* FROM Translation ORDER BY Translation.created DESC;
